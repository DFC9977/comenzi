{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": [
    {
      "target": "staging",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".git/**",
        "node_modules/**",
        "functions/**"
      ]
    },
    {
      "target": "prod",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        ".git/**",
        "node_modules/**",
        "functions/**"
      ]
    }
  ]
}
